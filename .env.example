# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Azure AI Foundry (recommended — bills to your Azure subscription) ─────────
# Your Foundry project endpoint. Find it in: Foundry portal → your project
# → View Deployments → select model → right pane → copy endpoint URL.
AZURE_OPENAI_ENDPOINT=https://<resource-name>.services.ai.azure.com/openai/v1

# Your model deployment name (as shown in Foundry → View Deployments)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Optional — only needed if NOT using keyless az login auth
# AZURE_OPENAI_API_KEY=

# ── Anthropic (alternative) ───────────────────────────────────────────────────
# From console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
