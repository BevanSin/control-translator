{
  "framework": {
    "id": "nzism",
    "version": "3.9",
    "short_name": "NZISM",
    "display_name": "New Zealand ISM",
    "reference_url": "https://www.nzism.gcsb.govt.nz/ism-document"
  },
  "ingest": { "type": "nzism", "source": "data/source/nzism2-3.9.csv",
              "classification_profile": "restricted" },
  "catalogue": { "type": "azure", "source": "data/cache/azure-builtins.json" },
  "mapping": {
    "engine": "agentic",
    "classifier": "azure-openai",
    "model": "${AZURE_OPENAI_DEPLOYMENT}",
    "foundry_base_url": "${AZURE_OPENAI_ENDPOINT}",
    "store": "data/mappings/nzism.json",
    "global_ignore": [
      "data/mappings/global-ignore.json",
      "data/mappings/nzism-ignore.json"
    ],
    "auto_approve": true,
    "confidence_threshold": 0.4,
    "concurrency": 5,
    "corrections": [
      "data/mappings/global-corrections.json",
      "data/mappings/nzism-corrections.json"
    ],
    "retrieval":          "embedding",
    "embedding_model":    "text-embedding-3-small",
    "embedding_endpoint": "${AZURE_OPENAI_ENDPOINT}",
    "exclude_patterns": [
      "customer-managed key",
      "customer managed key",
      "gcpol",
      "mission platform"
    ]
  },
  "build": {
    "type": "azure",
    "initiative_version": "1.0.0",
    "group_prefix": "New_Zealand_ISM_",
    "parameter_overrides": "data/parameters/nzism.json",
    "scope": "subscription",
    "enforcement_mode": "DoNotEnforce"
  },
  "distribute": { "type": "local" },
  "out_dir": "out"
}
