# ── generated outputs (never commit) ─────────────────────────────────────────
out/

# ── virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── user-managed working data ─────────────────────────────────────────────────
# These are YOUR data files. They must not be overwritten by a code sync.
# Back them up separately or commit selectively (see notes below).
data/cache/          # cached ARM built-in policy pull — regenerates automatically
data/catalogues/     # generated OSCAL catalogues — regenerated by ct
data/source/         # your framework CSV exports — download from the publisher

# Mapping decisions — the curated output of your runs.
# These are excluded by default because they contain framework-specific decisions
# that belong to the operator, not the shared tool.
# To track your NZISM mapping store in git: remove this line.
data/mappings/nzism.json

# OOS register — your curated list of globally-excluded policies.
# This IS worth tracking in git — it represents institutional knowledge.
# Explicitly UN-excluded below:
data/mappings/*.json
!data/mappings/global-ignore.json
!data/mappings/global-ignore.example.json
!data/mappings/nzism.example.json

# Parameter overrides
data/parameters/nzism.json
!data/parameters/nzism.example.json

# ── python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
dist/
build/

# ── editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
