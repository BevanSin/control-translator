# ── generated outputs ─────────────────────────────────────────────────────────
out/

# ── virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── user-managed working data ─────────────────────────────────────────────────
# Cached ARM built-in policy pull — regenerates automatically on first run
data/cache/

# Generated OSCAL catalogues — regenerated by ct ingest
data/catalogues/

# Framework CSV exports — download from the standard's publisher
data/source/

# Mapping store — your curated decisions (exclude by default; remove this line
# to track your decisions in git, which is recommended for team workflows)
data/mappings/nzism.json

# OOS register — worth tracking (institutional knowledge)
data/mappings/*.json
!data/mappings/global-ignore.json
!data/mappings/global-ignore.example.json
!data/mappings/nzism.example.json

# Parameter overrides — template tracked, live file excluded
data/parameters/nzism.json
!data/parameters/nzism.example.json

# ── secrets ───────────────────────────────────────────────────────────────────
# .env holds real API keys and endpoints — never commit it
# .env.example (no real values) IS committed as a setup guide
.env
.env.*
!.env.example

# ── user-specific configs (contain real endpoints / deployment names) ─────────
# Template configs use ${VAR} placeholders and ARE committed.
# Personal named configs are gitignored by convention.
config/*-local.json
config/*-local.yaml
config/*-myjob.json
config/nzism-gpt-test.json
config/nzism-claude-test.json

# ── python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
dist/
build/

# ── editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
